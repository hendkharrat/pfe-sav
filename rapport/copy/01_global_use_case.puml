@startuml Global_SAV_UseCase

left to right direction

skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #EBF5FB
  BorderColor #2E74B5
}
skinparam actor {
  BackgroundColor #FEF9E7
  BorderColor #B7950B
}

'================ ACTEURS ================
actor "Administrateur" as Admin
actor "Technicien" as Tech
actor "Client" as Cli

'================ HERITAGE ================
Admin --|> Tech

'================ ORDRE VERTICAL ================
Admin -[hidden]- Tech
Tech -[hidden]- Cli

'================ SYSTÈME ================
rectangle " " {

  '---------------- AUTH ----------------
  usecase "S'authentifier" as UC_AUTH

  '---------------- REFERENTIEL ----------------
  usecase "Gérer utilisateurs" as UC_USERS
  usecase "Gérer clients" as UC_CLIENTS
  usecase "Gérer équipements" as UC_EQUIP
  usecase "Gérer contrats" as UC_CONTRACTS

  '---------------- INTERVENTIONS ----------------
  usecase "Gérer interventions" as UC_INTERV
  usecase "Gérer pannes" as UC_PANNE
  usecase "Consulter planning" as UC_PLANNING

  '---------------- FACTURATION ----------------
  usecase "Générer facture" as UC_INVOICE
  usecase "Consulter factures" as UC_VIEW_INV

  '---------------- SUIVI ----------------
  usecase "Consulter historique" as UC_HISTORY
  usecase "Consulter tableau de bord" as UC_DASH
}

'================ INCLUDE AUTH ================
UC_USERS ..> UC_AUTH : <<include>>
UC_CLIENTS ..> UC_AUTH : <<include>>
UC_EQUIP ..> UC_AUTH : <<include>>
UC_CONTRACTS ..> UC_AUTH : <<include>>

UC_INTERV ..> UC_AUTH : <<include>>
UC_PANNE ..> UC_AUTH : <<include>>
UC_PLANNING ..> UC_AUTH : <<include>>

UC_INVOICE ..> UC_AUTH : <<include>>
UC_VIEW_INV ..> UC_AUTH : <<include>>

UC_HISTORY ..> UC_AUTH : <<include>>
UC_DASH ..> UC_AUTH : <<include>>

'================ ASSOCIATIONS ACTEURS ================

' Technicien (hérité par Admin)
Tech --> UC_INTERV
Tech --> UC_PLANNING
Tech --> UC_HISTORY
Tech --> UC_DASH

' Spécifique Administrateur
Admin --> UC_USERS
Admin --> UC_CLIENTS
Admin --> UC_EQUIP
Admin --> UC_CONTRACTS
Admin --> UC_INVOICE
Admin --> UC_VIEW_INV

' Client
Cli --> UC_PANNE
Cli --> UC_VIEW_INV
Cli --> UC_HISTORY
Cli --> UC_DASH

@enduml