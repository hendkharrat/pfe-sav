@startuml 19_sprint3_class_diagram

skinparam classBackgroundColor #EBF5FB
skinparam classBorderColor #2E74B5
skinparam noteBackgroundColor #FFFDE7
skinparam noteBorderColor #F39C12
skinparam linetype ortho

class User {
  + id : String
  + prenom : String
  + nom : String
  + role : String
  + actif : Boolean
}

class Client {
  + id : String
  + prenom : String
  + nom : String
  + email : String
}

class Contract {
  + id : String
  + reference : String
  + dateDebut : Date
  + dateFin : Date
  + statut : String
}

class Intervention {
  + id : String
  + type : String
  + datePrevue : Date
  + dateRealisation : Date
  + statut : String
  + couvertureContrat : Boolean
}

class Facture {
  + id : String
  + numero : String
  + dateEmission : Date
  + montantHT : Float
  + tva : Float
  + montantTTC : Float
  + statut : String
}

class LigneFacture {
  + description : String
  + quantite : Integer
  + prixUnitaire : Float
  + montant : Float
}

Intervention "1"    --   "0..1" Facture      : facturée par
Facture      "1"    *--  "*"    LigneFacture : contient
Client       "1"    --   "*"    Facture      : facturé
Client       "1"    --   "*"    Intervention : concerne
User         "0..1" --   "*"    Intervention : affecté (technicien)
Contract     "0..1" --   "*"    Intervention : planifie

@enduml
