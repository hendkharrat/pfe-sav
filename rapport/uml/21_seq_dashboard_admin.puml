@startuml 21_seq_dashboard_admin

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantBackgroundColor #EBF5FB
skinparam ParticipantBorderColor #2E74B5
skinparam NoteBackgroundColor #FFFDE7
skinparam NoteBorderColor #F39C12

actor       "Administrateur"               as Admin
participant "Interface\n(Frontend)"        as UI
participant "Contrôleur\n(DashboardCtrl)"  as CTRL
participant "Service\n(StatsService)"      as SVC
database    "Base de données\n(MySQL)"     as DB

Admin -> UI   : Accède au tableau de bord
UI    -> CTRL : GET /api/dashboard/admin

CTRL  -> SVC  : computeAdminStats()

SVC   -> DB   : SELECT COUNT(*), statut FROM interventions GROUP BY statut
DB    --> SVC  : { total, planifiees, enCours, realisees, annulees }

SVC   -> DB   : SELECT COUNT(*), statut FROM contracts GROUP BY statut
DB    --> SVC  : { actifs, bientotExpires, expires }

SVC   -> DB   : SELECT COUNT(*) FROM clients
DB    --> SVC  : totalClients

SVC   -> DB   : SELECT COUNT(*) FROM equipments
DB    --> SVC  : totalEquipments

SVC   -> DB   : SELECT SUM(montantTTC)\nFROM invoices\nWHERE statut = 'PAYEE'\nAND MONTH(dateEmission) = MONTH(NOW())
DB    --> SVC  : monthlyRevenue (TND)

SVC   -> DB   : SELECT COUNT(*) FROM invoices WHERE statut = 'IMPAYEE'
DB    --> SVC  : overdueInvoices

SVC   -> DB   : SELECT MONTH(datePrevue), COUNT(*)\nFROM interventions GROUP BY MONTH(datePrevue)
DB    --> SVC  : chartData

SVC   --> CTRL : DashboardStats { ... } + chartData
CTRL  --> UI   : 200 — { stats, chartData }
UI    --> Admin : Affiche dashboard :\n- KPIs (interventions, contrats, CA, factures)\n- Graphiques d'activité mensuelle
@enduml
