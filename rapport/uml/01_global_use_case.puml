@startuml 01_global_use_case
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle Hollow

' ── ACTEURS ──────────────────────────────────────
actor "Utilisateur"    as U
actor "Administrateur" as A
actor "Technicien"     as T
actor "Client"         as C

A --|> T
T --|> U
C --|> U

' ── SYSTÈME ──────────────────────────────────────
rectangle "Système SAV Manager" {

  note as N_AUTH
    Tous les cas d'utilisation métier
    nécessitent une authentification préalable.
  end note

  usecase "S'authentifier"                as UC01
  usecase "Se déconnecter"                as UC02

  usecase "Gérer les utilisateurs"        as UC03
  usecase "Gérer les clients"             as UC04
  usecase "Gérer les équipements"         as UC05
  usecase "Gérer les contrats"            as UC06
  usecase "Gérer les interventions"       as UC07
  usecase "Gérer les pannes"              as UC08
  usecase "Gérer les factures"            as UC09
  usecase "Consulter les factures"        as UC10
  usecase "Consulter le planning"         as UC11
  usecase "Consulter le tableau de bord"  as UC12
  usecase "Consulter l'historique"        as UC13

}

' ── ASSOCIATIONS ─────────────────────────────────
' Utilisateur — authentification uniquement
U --> UC01
U --> UC02

' Administrateur — gestion globale (hérite des cas de Technicien)
A --> UC03
A --> UC04
A --> UC05
A --> UC06
A --> UC08
A --> UC09

' Technicien — interventions et consultation (hérite de Utilisateur)
T --> UC07
T --> UC11
T --> UC12
T --> UC13

' Client — déclarations et consultation personnelle (hérite de Utilisateur)
C --> UC08
C --> UC10
C --> UC12
C --> UC13

@enduml
