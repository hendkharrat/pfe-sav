@startuml 06_seq_connexion
title Diagramme de séquence — CU-01 : S'authentifier\n(email ou numéro de téléphone)

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantBackgroundColor #EBF5FB
skinparam ParticipantBorderColor #2E74B5
skinparam SequenceGroupBodyBackgroundColor #FDFEFE
skinparam NoteBackgroundColor #FFFDE7
skinparam NoteBorderColor #F39C12

actor       "Utilisateur"              as User
participant "Interface\n(Frontend)"   as UI
participant "Contrôleur\n(AuthCtrl)"  as CTRL
participant "DAO\n(UserDAO/ClientDAO)" as DAO
database    "Base de données\n(MySQL)" as DB

User  -> UI   : Saisit identifiant + mot de passe
UI    -> CTRL : POST /api/auth/login { identifiant, password }

CTRL  -> CTRL : Détecte type d'identifiant\n(contient "@" → email\nsinon → téléphone 8 chiffres)

alt Identifiant = email
  CTRL -> DAO : findByEmail(identifiant)
  DAO  -> DB  : SELECT * FROM users WHERE email = ?
  DB   --> DAO : enregistrement ou null
  alt non trouvé dans users → cherche dans clients
    DAO  -> DB  : SELECT * FROM clients WHERE email = ?
    DB   --> DAO : enregistrement ou null
  end
else Identifiant = téléphone
  CTRL -> DAO : findByTelephone(identifiant)
  DAO  -> DB  : SELECT * FROM users WHERE telephone = ?
  DB   --> DAO : enregistrement ou null
  alt non trouvé dans users → cherche dans clients
    DAO  -> DB  : SELECT * FROM clients WHERE telephone = ?
    DB   --> DAO : enregistrement ou null
  end
end

DAO --> CTRL : utilisateur ou null

alt Utilisateur non trouvé
  CTRL --> UI : 401 — Identifiant incorrect
  UI   --> User : Affiche "Identifiant incorrect"
else Utilisateur trouvé
  CTRL -> CTRL : Vérifie hash du mot de passe
  alt Mot de passe incorrect
    CTRL --> UI : 401 — Mot de passe incorrect
    UI   --> User : Affiche "Mot de passe incorrect"
  else Compte inactif (actif = false)
    CTRL --> UI : 403 — Compte désactivé
    UI   --> User : Affiche "Compte désactivé"
  else Authentification réussie
    CTRL -> CTRL : Crée session { id, role, nom }
    CTRL --> UI  : 200 — { session }
    UI   --> User : Redirige vers tableau de bord\n(selon rôle : admin / technicien / client)
  end
end
@enduml
