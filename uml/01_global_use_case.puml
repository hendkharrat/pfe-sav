@startuml 01_global_use_case
title Diagramme de cas d'utilisation global — SAV Manager

left to right direction
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #EBF5FB
  BorderColor #2E74B5
  ArrowColor #2E74B5
}
skinparam actor {
  BackgroundColor #FEF9E7
  BorderColor #B7950B
}

actor "Administrateur" as Admin
actor "Technicien"      as Tech
actor "Client"          as Cli
actor "Système"         as Sys

rectangle "SAV Manager" {

  ' ---- Authentification ----
  usecase "Se connecter\n(email ou téléphone)" as UC01
  usecase "Se déconnecter"                     as UC02

  ' ---- Référentiel ----
  usecase "Gérer les utilisateurs internes\n(CRUD + désactivation + restauration)" as UC03
  usecase "Gérer les clients\n(SOCIETE / PERSONNE_PHYSIQUE)"                       as UC04
  usecase "Gérer le catalogue d'équipements\n(CLIMATISEUR / SYSTEME_SURPRESSION)"  as UC05
  usecase "Affecter équipement à client\n(ClientEquipement)"                       as UC06
  usecase "Gérer les contrats de maintenance"                                       as UC07

  ' ---- Interventions ----
  usecase "Affecter un technicien\n(vérification disponibilité)"  as UC09
  usecase "Consulter le planning\n(hebdomadaire / mensuel)"        as UC10
  usecase "Créer une intervention curative"                        as UC18
  usecase "Prendre en charge une panne"                            as UC13
  usecase "Convertir panne → intervention curative"               as UC14
  usecase "Démarrer une intervention"                              as UC12a
  usecase "Clôturer une intervention préventive\n(sans facture)"  as UC11
  usecase "Clôturer une intervention curative"                     as UC15b
  usecase "Consulter ses interventions"                            as UC17t
  usecase "Déclarer une panne\n(+ pièces jointes, sans priorité)" as UC12

  ' ---- Facturation ----
  usecase "Générer une facture\n(curative + réalisée + hors contrat)" as UC16
  usecase "Marquer une facture payée"                                  as UC18f
  usecase "Consulter les factures"                                     as UC17

  ' ---- Historique / Dashboard ----
  usecase "Consulter l'historique global"           as UC19
  usecase "Consulter l'historique personnel"        as UC19t
  usecase "Consulter l'historique client"           as UC19c
  usecase "Consulter le tableau de bord global"     as UC20a
  usecase "Consulter le tableau de bord technicien" as UC20t
  usecase "Consulter l'espace client"               as UC20c
  usecase "Filtrer / Rechercher / Paginer"          as UC28

  ' ---- Système automatique ----
  usecase "Générer automatiquement\nle planning préventif"       as US_SYS1
  usecase "Calculer statut des contrats\n(ACTIF / BIENTOT_EXPIRE / EXPIRE)" as US_SYS2
  usecase "Vérifier disponibilité\ntechnicien par date"           as US_SYS3
  usecase "Vérifier couverture\ncontractuelle"                    as US_SYS4
  usecase "Calculer montant facture\n(TVA 19 %, TND)"             as US_SYS5
}

' --- Admin associations ---
Admin --> UC01
Admin --> UC02
Admin --> UC03
Admin --> UC04
Admin --> UC05
Admin --> UC06
Admin --> UC07
Admin --> UC09
Admin --> UC10
Admin --> UC18
Admin --> UC13
Admin --> UC14
Admin --> UC16
Admin --> UC18f
Admin --> UC17
Admin --> UC19
Admin --> UC20a
Admin --> UC28

' --- Technicien associations ---
Tech --> UC01
Tech --> UC02
Tech --> UC10
Tech --> UC12a
Tech --> UC11
Tech --> UC15b
Tech --> UC17t
Tech --> UC19t
Tech --> UC20t

' --- Client associations ---
Cli --> UC01
Cli --> UC02
Cli --> UC12
Cli --> UC17
Cli --> UC19c
Cli --> UC20c

' --- Système associations ---
Sys --> US_SYS1
Sys --> US_SYS2
Sys --> US_SYS3
Sys --> US_SYS4
Sys --> US_SYS5

' --- include / extend ---
UC07 ..> US_SYS1 : <<include>>
UC07 ..> US_SYS2 : <<include>>
UC09 ..> US_SYS3 : <<include>>
UC15b ..> US_SYS4 : <<include>>
UC16 ..> US_SYS5 : <<include>>

@enduml
